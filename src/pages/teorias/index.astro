---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('teorias')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Teorías · Fishie Files">
  <main class="section">
    <span class="eyebrow">Sospechas elegantes</span>
    <h1>Teorías</h1>
    <p>Hipótesis, conexiones, patrones y pequeñas obsesiones con estructura.</p>
    <div class="grid">
      {entries.map((entry) => (
        <ArticleCard title={entry.data.title} description={entry.data.description} href={`${import.meta.env.BASE_URL}teorias/${entry.slug}/`} tags={entry.data.tags} />
      ))}
    </div>
  </main>
</BaseLayout>
