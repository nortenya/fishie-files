---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('lore')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Lore · Fishie Files">
  <main class="section">
    <span class="eyebrow">Canon y contexto</span>
    <h1>Lore</h1>
    <p>Notas sobre eventos, símbolos, contexto narrativo y piezas del universo.</p>
    <div class="grid">
      {entries.map((entry) => (
        <ArticleCard title={entry.data.title} description={entry.data.description} href={`${import.meta.env.BASE_URL}lore/${entry.slug}/`} tags={entry.data.tags} />
      ))}
    </div>
  </main>
</BaseLayout>
