---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allEntries = [
  ...(await getCollection('analisis')),
  ...(await getCollection('lore')),
  ...(await getCollection('teorias')),
  ...(await getCollection('timeline'))
].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = allEntries.filter((entry) => entry.data.featured).slice(0, 3);
---

<BaseLayout>
  <main>
    <section class="hero">
      <div>
        <span class="eyebrow">Rafayel archive · lore · personality · theories</span>

        <h1>Fishie Files</h1>

        <p class="hero-copy">
          A personal archive to understand Rafayel, his symbolism, and put an end to his mischaracterization.
        </p>

        <div class="button-row">
          <a class="button primary" href={`${import.meta.env.BASE_URL}analisis/`}>
            Read analysis
          </a>

          <a class="button ghost" href={`${import.meta.env.BASE_URL}timeline/`}>
            View timeline
          </a>
        </div>
      </div>

      <div class="hero-card archive-card">
        <div class="archive-card-text">
          <p class="card-title">Active record</p>

          <p class="quote">
            "When your own heart is devouring you, is there anything that can pull you back?"
          </p>
        </div>

        <div class="archive-image-frame">
          <img
            class="archive-image"
            src={`${import.meta.env.BASE_URL}images/saphiredream.jpg`}
            alt="Archive record visual"
          />
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">Featured</span>
          <h2>Main entries</h2>
        </div>

        <p>Start here whenever you’re ready to dive into the deep sea.</p>
      </div>

      <div class="grid">
        {featured.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            description={entry.data.description}
            href={`${import.meta.env.BASE_URL}${entry.collection}/${entry.slug}/`}
            tags={entry.data.tags}
          />
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-head">
        <div>
          <span class="eyebrow">Sections</span>
          <h2>Archive map</h2>
        </div>
      </div>

      <div class="grid">
        <a class="card" href={`${import.meta.env.BASE_URL}analisis/`}>
          <h3>Personality</h3>

          <p>
            Rasgos, contradicciones, vulnerabilidad, forma de amar y mecanismos de defensa.
          </p>

          <div class="tag-list">
            <span class="tag">psicología</span>
            <span class="tag">dinámica</span>
          </div>
        </a>

        <a class="card" href={`${import.meta.env.BASE_URL}lore/`}>
          <h3>Lore</h3>

          <p>
            Eventos, símbolos, contexto y piezas narrativas que explican su historia.
          </p>

          <div class="tag-list">
            <span class="tag">canon</span>
            <span class="tag">mundo</span>
          </div>
        </a>

        <a class="card" href={`${import.meta.env.BASE_URL}teorias/`}>
          <h3>Theories</h3>

          <p>
            Hipótesis con evidencia, sospechas elegantes y conexiones que duelen rico.
          </p>

          <div class="tag-list">
            <span class="tag">evidencia</span>
            <span class="tag">spoilers</span>
          </div>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>