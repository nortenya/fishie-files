<div class="ocean-cursor-layer" aria-hidden="true"></div>

<script is:inline>
  (() => {
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;

    const layer = document.querySelector(".ocean-cursor-layer");
    if (!layer) return;

    let lastBubble = 0;

    function createBubble(x, y) {
      const now = performance.now();

      // Entre más alto el número, menos burbujas salen
      if (now - lastBubble < 55) return;
      lastBubble = now;

      const bubble = document.createElement("span");
      bubble.className = "cursor-bubble";

      const size = Math.random() * 12 + 6;
      const drift = (Math.random() - 0.5) * 46;
      const rise = Math.random() * 48 + 44;
      const duration = Math.random() * 700 + 900;

      bubble.style.setProperty("--size", `${size}px`);
      bubble.style.setProperty("--x", `${x}px`);
      bubble.style.setProperty("--y", `${y}px`);
      bubble.style.setProperty("--drift", `${drift}px`);
      bubble.style.setProperty("--rise", `${rise}px`);
      bubble.style.setProperty("--duration", `${duration}ms`);

      layer.appendChild(bubble);

      window.setTimeout(() => {
        bubble.remove();
      }, duration + 150);
    }

    window.addEventListener(
      "pointermove",
      (event) => {
        if (event.pointerType === "touch") return;
        createBubble(event.clientX, event.clientY);
      },
      { passive: true }
    );
  })();
</script>

<style is:global>
  .ocean-cursor-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 9999;
  }

  .cursor-bubble {
    position: fixed;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    pointer-events: none;
    border-radius: 999px;
    border: 1px solid rgba(255, 240, 245, 0.42);
    background:
      radial-gradient(circle at 30% 28%, rgba(255, 255, 255, 0.9), transparent 18%),
      radial-gradient(circle at 58% 62%, rgba(110, 198, 202, 0.30), transparent 48%),
      radial-gradient(circle, rgba(255, 122, 107, 0.20), transparent 70%);
    box-shadow:
      0 0 14px rgba(110, 198, 202, 0.18),
      0 0 22px rgba(255, 122, 107, 0.10);
    animation: cursor-bubble-rise var(--duration) ease-out forwards;
    will-change: transform, opacity;
  }

  @keyframes cursor-bubble-rise {
    0% {
      opacity: 0;
      transform: translate(-50%, -50%) scale(0.35);
      filter: blur(0);
    }

    18% {
      opacity: 0.65;
    }

    100% {
      opacity: 0;
      transform:
        translate(
          calc(-50% + var(--drift)),
          calc(-50% - var(--rise))
        )
        scale(1.45);
      filter: blur(1px);
    }
  }

  @media (max-width: 820px) {
    .ocean-cursor-layer {
      display: none;
    }
  }
</style>