---
import '../styles/global.css';
import OceanCursor from "../components/OceanCursor.astro";

const {
  title = 'Fishie Files',
  description = 'Analysis, lore, and theories file about Rafayel.'
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
  <OceanCursor />
    <header class="nav">
      <a class="brand" href={`${import.meta.env.BASE_URL}`}>
        <span class="brand-mark">🐟</span>
        <span>Fishie Files</span>
      </a>
      <nav class="nav-links" aria-label="Main Navigation">
        <a href={`${import.meta.env.BASE_URL}`}>Home</a>
        <a href={`${import.meta.env.BASE_URL}analisis/`}>Analysis</a>
        <a href={`${import.meta.env.BASE_URL}lore/`}>Lore</a>
        <a href={`${import.meta.env.BASE_URL}teorias/`}>Theories</a>
        <a href={`${import.meta.env.BASE_URL}timeline/`}>Timeline</a>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <small>Fishie Files · Personal analysis file: Where his beloved bride tries to understand him better.</small>
    </footer>
  </body>
</html>
