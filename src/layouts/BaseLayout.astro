---
import '../styles/global.css';

const {
  title = 'Fishie Files',
  description = 'Archivo de análisis, lore y teorías sobre Rafayel.'
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="nav">
      <a class="brand" href={`${import.meta.env.BASE_URL}`}>
        <span class="brand-mark">🐟</span>
        <span>Fishie Files</span>
      </a>
      <nav class="nav-links" aria-label="Navegación principal">
        <a href={`${import.meta.env.BASE_URL}`}>Inicio</a>
        <a href={`${import.meta.env.BASE_URL}analisis/`}>Análisis</a>
        <a href={`${import.meta.env.BASE_URL}lore/`}>Lore</a>
        <a href={`${import.meta.env.BASE_URL}teorias/`}>Teorías</a>
        <a href={`${import.meta.env.BASE_URL}timeline/`}>Timeline</a>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <small>Fishie Files · Archivo personal de análisis. Hecho con amor, océano y demasiadas teorías.</small>
    </footer>
  </body>
</html>
