---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---
<BaseLayout title={`${frontmatter.title} · Fishie Files`} description={frontmatter.description}>
  <main class="article">
    <a class="eyebrow" href={`${import.meta.env.BASE_URL}`}>← Volver al archivo</a>
    <h1>{frontmatter.title}</h1>
    <div class="article-meta">
      {frontmatter.date?.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
      {frontmatter.mood && <> · Mood: {frontmatter.mood}</>}
    </div>
    <div class="article-content">
      <slot />
    </div>
  </main>
</BaseLayout>
